# LLM Provider Selection
# Options: "ollama" (default) or "openai"
LLM_PROVIDER=ollama

# Ollama Configuration
# Get your key at https://ollama.com/settings/keys
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_HOST=https://ollama.com
OLLAMA_MODEL=gpt-oss:120b-cloud

# OpenAI Configuration (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo

# Langfuse Observability
# Obtain keys at https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# GitHub Integration (Optional)
# Personal Access Token for increased rate limits (5000 req/hr)
GITHUB_TOKEN=your_github_personal_access_token

# Company name for generated emails
COMPANY_NAME=our company

# Application Settings
LOG_LEVEL=INFO
